# ═══════════════════════════════════════════
# Configuration - Détection de Fraude Temps Réel
# ═══════════════════════════════════════════
# Dupliquer ce fichier en .env et modifier les valeurs
# cp .env.example .env

# ── Kafka ──────────────────────────────
KAFKA_HOST=localhost
KAFKA_PORT=9092

# ── Cassandra ──────────────────────────
CASSANDRA_HOST=localhost
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=fraud_detection

# ── Redis ──────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_ALERT_KEY=fraud:alerts:recent

# ── MinIO ──────────────────────────────
MINIO_ENDPOINT=localhost:9002
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=password123
MINIO_BUCKET=transactions

# ── API FastAPI ────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Metrics Prometheus ─────────────────
METRICS_PORT=8001

# ── Flink PyFlink ──────────────────────
KAFKA_JAR=file:///opt/flink/lib/flink-sql-connector-kafka-2.3.0.jar
